# NEVER commit actual secrets. This file documents expected variables only.

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare Access (JWT verification)
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# Master Registry D1
MASTER_REGISTRY_D1_ID=

# Tenant D1 (for tenant-runtime-worker)
TENANT_D1_ID=

# R2
PLATFORM_R2_BUCKET=

# Workers AI / AI Gateway
AI_GATEWAY_ENDPOINT=
AI_GATEWAY_TOKEN=

# Observability
LOG_LEVEL=info

# Dashboard (Next.js public vars)
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_API_URL=

# Feature Flags
FEATURE_FLAG_PROVIDER=

# Node environment
NODE_ENV=development
